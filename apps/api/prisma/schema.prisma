generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings          UserSettings?
  readingProgress   ReadingProgress[]
  reviews           UserReview[]
  annotations       Annotation[]
  shelves           Shelf[]
  libraries         Library[]
  bookLibraries     UserBookLibrary[]
  recipientEmails   RecipientEmail[]
  smtpConfig        UserSmtpConfig?
  koReaderCredential KoReaderCredential?
  readingQueue       ReadingQueueItem[]
  audiobookProgress  AudiobookProgress[]
  podcastProgress    PodcastEpisodeProgress[]
}

enum Role {
  USER
  ADMIN
}

enum AnnotationType {
  HIGHLIGHT
  UNDERLINE
  STRIKETHROUGH
  BOOKMARK
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  theme                 String  @default("auto")
  dashboardLayout       String? // JSON: DashboardSection[]
  bookItemSize          String  @default("md") // "sm" | "md" | "lg" | "xl"
  progressDisplaySource String  @default("HIGHEST") // "HIGHEST" | "MOST_RECENT" | "KOREADER" | "LITARA"
}

model Library {
  id          String   @id @default(uuid())
  name        String
  description String?
  userId      String?  // null = system library (scanner); non-null = user-owned
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  books     Book[]
  userBooks UserBookLibrary[]
}

model Book {
  id            String    @id @default(uuid())
  libraryId     String?
  library       Library?  @relation(fields: [libraryId], references: [id], onDelete: SetNull)
  // Metadata fields
  title         String
  subtitle      String?
  description   String?
  publishedDate DateTime?
  isbn13        String?
  isbn10        String?
  coverData     Bytes?    // raw image bytes extracted from file
  publisher     String?
  language      String?
  pageCount     Int?
  ageRating     String?
  tags            Tag[]
  genres          Genre[]
  moods           Mood[]
  authors         BookAuthor[]
  series          SeriesBook[]
  // External metadata links
  googleBooksId   String?
  openLibraryId   String?
  asin            String?
  goodreadsId     String?
  goodreadsRating Float?

  hasAudiobook  Boolean   @default(false)
  lockedFields  String    @default("[]") // JSON: string[] of field names
  sidecarFile   String?   // absolute path to matched .metadata.json
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  files           BookFile[]
  audiobookFiles  AudiobookFile[]
  audiobookProgress  AudiobookProgress[]

  readingProgress ReadingProgress[]
  reviews         UserReview[]
  annotations     Annotation[]
  shelves         BookShelf[]
  userLibraries   UserBookLibrary[]
  readingQueue    ReadingQueueItem[]
}

model Author {
  id          String   @id @default(uuid())
  name        String   @unique
  biography   String?
  photoData   Bytes?
  goodreadsId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  books BookAuthor[]
}


model BookAuthor {
  bookId   String
  authorId String
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  author   Author @relation(fields: [authorId], references: [id], onDelete: Cascade)
  role     String @default("Author") // e.g., Author, Illustrator, Translator

  @@id([bookId, authorId])
}

model Series {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  totalBooks  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  books SeriesBook[]
  slots SeriesSlot[]
}

model SeriesSlot {
  id         String   @id @default(uuid())
  seriesId   String
  series     Series   @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  title      String
  sequence   Float?
  authors    String[]
  coverData  Bytes?
  provider   String
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([seriesId, sequence])
}

model SeriesBook {
  seriesId String
  bookId   String
  series   Series @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  sequence Float? // Can be 1, 1.5, 2, etc.

  @@id([seriesId, bookId])
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  books Book[]
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  books Book[]
}

model Mood {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  books Book[]
}

model BookFile {
  id        String   @id @default(uuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  filePath  String   // Path relative to library storage root
  format    String   // e.g., EPUB, PDF, CBZ
  sizeBytes BigInt
  fileHash  String?  // SHA-256 for duplicate detection
  koReaderHash String? // MD5 for KOReader document identification
  missingAt DateTime? // Set when chokidar detects the file has been removed from disk

  createdAt DateTime @default(now())
}

model WatchedFolder {
  id        String   @id @default(uuid())
  path      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum ProgressSource {
  LITARA   // Built-in Litara reader (web now, mobile in future)
  KOREADER // KOReader device sync
}

model ReadingProgress {
  id           String         @id @default(uuid())
  userId       String
  bookId       String
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  book         Book           @relation(fields: [bookId], references: [id], onDelete: Cascade)

  source       ProgressSource @default(LITARA)

  // Store location in whatever format reader uses (e.g., EPUB CFI, page number)
  location     String?
  percentage   Float?

  // KOReader-specific fields (null for non-KOReader progress)
  koReaderProgress  String? // KOReader internal progress string (CFI or page)
  koReaderDevice    String? // Device name reported by KOReader
  koReaderDeviceId  String? // Device identifier reported by KOReader
  koReaderTimestamp Int?    // Unix timestamp from KOReader sync

  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([userId, bookId, source]) // One progress record per user per book per source
}

model UserReview {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  rating     Float?   // half-stars supported (e.g. 2.5, 4.5)
  readStatus String  @default("UNREAD") // UNREAD | READING | READ | WONT_READ
  reviewText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, bookId])
}

model UserBookLibrary {
  id         String   @id @default(uuid())
  userId     String
  bookId     String
  libraryId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book       Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  library    Library  @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  assignedAt DateTime @default(now())

  @@unique([userId, bookId]) // one library assignment per book per user
}

model Annotation {
  id        String   @id @default(uuid())
  userId    String
  bookId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  type      AnnotationType @default(HIGHLIGHT)
  location  String   // EPUB CFI or PDF coordinate
  text      String?  // The text that was highlighted
  note      String?  // User's comment on the highlight
  color     String?  // Highlight color

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shelf {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String
  isSmart   Boolean  @default(false)
  logic     String   @default("AND") // AND | OR

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  books BookShelf[]
  rules SmartShelfRule[]
}

model BookShelf {
  shelfId String
  bookId  String
  shelf   Shelf  @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  book    Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  addedAt DateTime @default(now())

  @@id([shelfId, bookId])
}

model SmartShelfRule {
  id        String   @id @default(uuid())
  shelfId   String
  shelf     Shelf    @relation(fields: [shelfId], references: [id], onDelete: Cascade)

  field     String   // e.g., "genre", "rating", "author"
  operator  String   // e.g., "EQUALS", "CONTAINS", "GREATER_THAN"
  value     String   // e.g., "Sci-Fi", "4"
}

model ReadingQueueItem {
  id       String   @id @default(uuid())
  userId   String
  bookId   String
  position Int
  addedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, position])
}

model Task {
  id          String   @id @default(uuid())
  type        String   // e.g., "METADATA_FETCH", "FILE_IMPORT"
  status      String   // e.g., "PENDING", "PROCESSING", "COMPLETED", "FAILED"
  payload     String?  // JSON blob with task-specific data
  errorMessage String?

  nextRunTime DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Log {
  id        String   @id @default(uuid())
  level     String   // e.g., "INFO", "WARN", "ERROR"
  message   String
  metadata  String?  // JSON blob for extra context
  timestamp DateTime @default(now())
}

model ServerSettings {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // Store as JSON string to support various data types
  updatedAt DateTime @updatedAt
}

model RecipientEmail {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String
  label     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, email])
}

model UserSmtpConfig {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  host              String
  port              Int
  fromAddress       String
  username          String
  encryptedPassword String
  enableAuth        Boolean  @default(true)
  enableStartTls    Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model OpdsUser {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // bcrypt hashed
  createdAt DateTime @default(now())
}

model KoReaderCredential {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   // bcrypt(MD5) for v2; raw MD5 for v1 legacy rows
  hashVersion  Int      @default(1) // 1 = raw MD5 (legacy), 2 = bcrypt(MD5)
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

enum PendingBookStatus {
  PENDING
  APPROVED
  REJECTED
  COLLISION
}

model AudiobookFile {
  id        String   @id @default(uuid())
  bookId    String
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  filePath  String   @unique
  fileHash  String
  fileSize  BigInt?
  fileIndex Int
  duration  Float
  mimeType  String
  narrator  String?
  createdAt DateTime @default(now())

  chapters AudiobookChapter[]
}

model AudiobookChapter {
  id              String        @id @default(uuid())
  audiobookFileId String
  audiobookFile   AudiobookFile @relation(fields: [audiobookFileId], references: [id], onDelete: Cascade)
  index           Int
  title           String
  startTime       Float
  endTime         Float?
}

model AudiobookProgress {
  id               String    @id @default(uuid())
  userId           String
  bookId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book             Book      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  currentFileIndex Int       @default(0)
  currentTime      Float     @default(0)
  totalDuration    Float
  completedAt      DateTime?
  updatedAt        DateTime  @updatedAt

  @@unique([userId, bookId])
}

enum DownloadPolicy {
  ALL
  LATEST_N
  MANUAL
}

enum RetentionPolicy {
  KEEP_ALL
  DELETE_AFTER_LISTENED
  KEEP_LATEST_N
}

enum EpisodeDownloadStatus {
  NOT_DOWNLOADED
  PENDING
  DOWNLOADING
  DOWNLOADED
  FAILED
}

model Podcast {
  id                     String          @id @default(uuid())
  feedUrl                String          @unique
  title                  String
  description            String?
  artworkUrl             String?
  author                 String?
  websiteUrl             String?
  lastRefreshedAt        DateTime?
  nextRefreshAt          DateTime?
  refreshIntervalMinutes Int             @default(60)
  downloadPolicy         DownloadPolicy  @default(MANUAL)
  keepLatestN            Int?
  retentionPolicy        RetentionPolicy @default(KEEP_ALL)
  subscribed             Boolean         @default(true)
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  episodes PodcastEpisode[]
}

model PodcastEpisode {
  id             String                @id @default(uuid())
  podcastId      String
  podcast        Podcast               @relation(fields: [podcastId], references: [id], onDelete: Cascade)
  guid           String
  title          String
  description    String?
  publishedAt    DateTime?
  duration       Float?
  audioUrl       String
  downloadStatus EpisodeDownloadStatus @default(NOT_DOWNLOADED)
  downloadPath   String?
  fileSize       BigInt?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  progress PodcastEpisodeProgress[]

  @@unique([podcastId, guid])
}

model PodcastEpisodeProgress {
  id          String         @id @default(uuid())
  userId      String
  episodeId   String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode     PodcastEpisode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  currentTime Float          @default(0)
  updatedAt   DateTime       @updatedAt

  @@unique([userId, episodeId])
}

model PendingBook {
  id               String            @id @default(uuid())
  status           PendingBookStatus @default(PENDING)

  // File info
  stagedFilePath   String
  fileHash         String
  originalFilename String

  // Metadata (editable by admin before approval)
  title            String?
  subtitle         String?
  authors          String    @default("[]") // JSON: string[]
  seriesName       String?
  seriesPosition   Float?
  seriesTotalBooks Int?
  publisher        String?
  publishedDate    DateTime?
  language         String?
  description      String?
  isbn10           String?
  isbn13           String?
  pageCount        Int?
  genres           String    @default("[]") // JSON: string[]
  tags             String    @default("[]") // JSON: string[]
  moods            String    @default("[]") // JSON: string[]
  googleBooksId    String?
  openLibraryId    String?
  goodreadsId      String?
  asin             String?
  goodreadsRating  Float?
  coverUrl         String?

  // Write resolution
  targetPath       String?
  collidingPath    String?
  overwriteApproved Boolean  @default(false)

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}
